{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "../dist/server",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "noEmit": false,
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
